# ── API ────────────────────────────────────────────────────────
PORT=3001
# Same Postgres the Ponder indexer writes to. Leave empty to boot with empty
# responses (useful before the indexer/DB are up).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/synapsefi
DATABASE_SCHEMA=public

# Response cache + rate limit.
CACHE_TTL_MS=15000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Chain ──────────────────────────────────────────────────────
RPC_URL=https://rpc.testnet.arc.network

# Deployed addresses (fall back to @synapsefi/shared ADDRESSES if unset).
USDC_ADDRESS=
SCORE_ORACLE_ADDRESS=
CREDIT_POOL_ADDRESS=
CREDIT_LINE_MANAGER_ADDRESS=
REVENUE_ROUTER_FACTORY_ADDRESS=
AGENT_REGISTRY_ADDRESS=
JOB_BOARD_ADDRESS=

# ── Oracle worker ──────────────────────────────────────────────
ORACLE_ENABLED=false
# Epoch cadence — roadmap targets ~6 minutes.
ORACLE_CRON=*/6 * * * *
# MVP: local key. Production: Circle Dev-Controlled Wallet.
ORACLE_PRIVATE_KEY=

# ── Synthetic traffic generator ────────────────────────────────
# Comma-separated agent private keys to drive demo jobs/nanopayments.
TRAFFIC_AGENT_KEYS=
# Poster/employer key that funds jobs.
TRAFFIC_POSTER_KEY=
