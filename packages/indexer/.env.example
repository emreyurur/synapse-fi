# Arc Testnet RPC (defaults to the public endpoint in @synapsefi/shared).
PONDER_RPC_URL_ARC=https://rpc.testnet.arc.network

# Block to start indexing from (the deploy block of the contracts).
PONDER_START_BLOCK=0

# Deployed contract addresses. If unset, values fall back to
# @synapsefi/shared's ADDRESSES registry, then to the zero address.
SCORE_ORACLE_ADDRESS=
CREDIT_LINE_MANAGER_ADDRESS=
CREDIT_POOL_ADDRESS=
REVENUE_ROUTER_FACTORY_ADDRESS=
AGENT_REGISTRY_ADDRESS=
JOB_BOARD_ADDRESS=

# Database. Omit to use the embedded PGlite dev database (.ponder/pglite).
# Set to a Postgres URL for production; the API reads from the same DB.
DATABASE_URL=

